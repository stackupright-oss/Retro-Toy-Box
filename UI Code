const Starfield = () => {
  const canvasRef = useRef(null);
  useEffect(() => {
    const canvas = canvasRef.current;
    const ctx = canvas.getContext('2d');
    let animationFrameId;
    let stars = Array.from({ length: 100 }, () => ({ x: Math.random() * canvas.width, y: Math.random() * canvas.height, z: Math.random() * 2, speed: Math.random() * 5 + 1 }));
    const render = () => {
      ctx.fillStyle = '#000'; ctx.fillRect(0, 0, canvas.width, canvas.height); ctx.fillStyle = '#0f0';
      stars.forEach(star => {
        star.x = (star.x - canvas.width / 2) * (canvas.width / 2 + star.z) / (canvas.width / 2) + canvas.width / 2;
        star.y = (star.y - canvas.height / 2) * (canvas.width / 2 + star.z) / (canvas.width / 2) + canvas.height / 2;
        star.z -= star.speed;
        if (star.z <= 0) { star.z = canvas.width; star.x = Math.random() * canvas.width; star.y = Math.random() * canvas.height; }
        const size = (canvas.width - star.z) / canvas.width * 2;
        ctx.fillRect((star.x - canvas.width / 2) * (canvas.width / star.z) + canvas.width / 2, (star.y - canvas.height / 2) * (canvas.width / star.z) + canvas.height / 2, size, size);
      });
      animationFrameId = requestAnimationFrame(render);
    };
    canvas.width = canvas.offsetWidth; canvas.height = canvas.offsetHeight; render();
    return () => cancelAnimationFrame(animationFrameId);
  }, []);
  return <canvas ref={canvasRef} className="w-full h-full opacity-80" />;
};

