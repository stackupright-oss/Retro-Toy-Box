/*
 * TIC TAC TOE (WARGAMES MODE)
 * The only winning move is not to play.
 */
const GlobalThermonuclearWar = ({ onGameOver }) => {
    const [board, setBoard] = useState(Array(9).fill(null));
    const [isPlayerTurn, setIsPlayerTurn] = useState(true);
    const [status, setStatus] = useState("AWAITING INPUT");

    const checkWinner = (squares) => {
        const lines = [[0,1,2],[3,4,5],[6,7,8],[0,3,6],[1,4,7],[2,5,8],[0,4,8],[2,4,6]];
        for (let i = 0; i < lines.length; i++) {
            const [a,b,c] = lines[i];
            if (squares[a] && squares[a] === squares[b] && squares[a] === squares[c]) return squares[a];
        }
        return null;
    };

    useEffect(() => {
        if (!isPlayerTurn && !checkWinner(board) && board.includes(null)) {
            const timer = setTimeout(() => {
                const emptyIndices = board.map((v, i) => v === null ? i : null).filter(v => v !== null);
                const randomMove = emptyIndices[Math.floor(Math.random() * emptyIndices.length)];
                
                const newBoard = [...board];
                newBoard[randomMove] = 'O';
                setBoard(newBoard);
                setIsPlayerTurn(true);
                playSound('key');
            }, 800);
            return () => clearTimeout(timer);
        }
    }, [isPlayerTurn, board]);

    const handleClick = (i) => {
        if (board[i] || !isPlayerTurn || checkWinner(board)) return;
        const newBoard = [...board];
        newBoard[i] = 'X';
        setBoard(newBoard);
        setIsPlayerTurn(false);
        playSound('key');
    };

    const winner = checkWinner(board);
    const isDraw = !winner && !board.includes(null);

    useEffect(() => {
        if (winner) {
            setStatus(`WINNER: ${winner}`);
            playSound(winner === 'X' ? 'win' : 'alert');
        } else if (isDraw) {
            setStatus("STALEMATE DETECTED");
            setTimeout(() => {
                onGameOver("A STRANGE GAME. THE ONLY WINNING MOVE IS NOT TO PLAY.");
            }, 2000);
        }
    }, [winner, isDraw, onGameOver]);

    return (
        <div className="h-full flex flex-col items-center justify-center">
            <div className="mb-4 text-center animate-pulse">{status}</div>
            <div className="grid grid-cols-3 gap-1 bg-green-900/50 p-1">
                {board.map((cell, i) => (
                    <button 
                        key={i} 
                        onClick={() => handleClick(i)}
                        className="w-16 h-16 md:w-20 md:h-20 border border-green-500 flex items-center justify-center text-3xl font-bold hover:bg-green-500/20 disabled:cursor-not-allowed"
                        disabled={!!cell || !isPlayerTurn || !!winner}
                    >
                        {cell}
                    </button>
                ))}
            </div>
            <div className="mt-4 text-xs">PLAYERS: 1 (VS JOSHUA)</div>
        </div>
    );
};

